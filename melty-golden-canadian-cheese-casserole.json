    },
    {
      "name": "Salt",
      "amount": "1/4 teaspoon",
      "notes": "to taste"
    },
    {
      "name": "Pepper",
      "amount": "1/8 teaspoon",
      "notes": "to taste"
    },
    {
      "name": "Fresh Parsley",
      "amount": "1 tablespoon",
      "notes": "chopped (optional)"
    }
  ],
  "instructions": [
    "Preheat the oven to 375°F (190°C).",
    "Melt the butter in a saucepan over medium heat.",
    "Add the Golden Canadian Cheese Blend and stir until melted and smooth.",
    "Add the Melty Cheese and stir until well combined.",
    "In a separate bowl, whisk together the Milk, Eggs, Salt, and Pepper.",
    "Pour the wet ingredients into the cheese mixture and stir until smooth.",
    "Pour the mixture into the prepared Casserole pan.",
    "Bake for 25-30 minutes, or until the casserole is golden brown and set.",
    "Remove from the oven and sprinkle with chopped Fresh Parsley (if using).",
    "Let cool for 5-10 minutes before serving."
  ],
