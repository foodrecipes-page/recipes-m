    {
      "name": "ferment-jang",
      "amount": "1 tablespoon"
    },
    {
      "name": "basmati rice",
      "amount": "2 cups"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in a wok over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and cook for an additional minute.",
    "Add the malt syrup, ferment-jang, and salt, stirring to combine.",
    "Add the basmati rice and stir to coat the rice in the malty mixture.",
    "Add 4 cups of water to the wok and bring to a boil.",
    "Reduce the heat to low, cover the wok, and simmer for 20 minutes.",
    "Fluff the pilaf with a fork and stir in the chopped pistachios.",
    "Serve hot and enjoy."
  ],
