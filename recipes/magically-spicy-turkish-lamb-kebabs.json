    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "gluten-free bread",
      "amount": "4 slices",
      "notes": "toasted"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the grill to medium-high heat.",
    "In a large bowl, whisk together olive oil, lemon juice, garlic, salt, black pepper, and crushed dried red chillies.",
    "Add the lamb cubes to the bowl and mix until they are well coated with the marinade.",
    "Thread the lamb cubes onto skewers, leaving a small space between each cube.",
    "Grill the lamb kebabs for 10 minutes, turning occasionally, until they are cooked through.",
    "Toast the gluten-free bread slices.",
    "Serve the lamb kebabs with toasted bread and garnish with chopped fresh parsley.",
    "Offer additional lemon wedges on the side for those who prefer extra tanginess."
  ],
