{
  "title": "Mildly Spicy Slovakian Lamb Stew",
  "description": "A floral and pillowy Slovakian dish featuring garam masala, this stew is made in a molcajete and is anti-inflammatory friendly. It has a unique flavor profile with a monsoon twist.",
  "cuisine": "Slovakian",
  "diet": [
    "gluten-free",
    "dairy-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "lamb shoulder",
      "amount": "1 1/2 pounds",
      "notes": "cut into 1 1/2 inch pieces"
    },
    {
      "name": "garam masala",
      "amount": "2 teaspoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "carrot",
      "amount": "2 medium",
      "notes": "peeled and chopped"
    },
    {
      "name": "potato",
      "amount": "2 medium",
      "notes": "peeled and chopped"
    },
    {
      "name": "chicken broth",
      "amount": "4 cups"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Heat the olive oil in the molcajete over medium heat.",
    "Add the lamb pieces and cook until browned on all sides, about 5 minutes.",
    "Add the onion and garlic and cook until the onion is translucent, about 5 minutes.",
    "Add the garam masala, salt, and black pepper, and stir to combine.",
    "Add the carrot and potato, and stir to combine.",
    "Pour in the chicken broth and bring to a boil.",
    "Reduce the heat to low and simmer, covered, until the lamb is tender, about 1 1/2 hours.",
    "Serve hot, garnished with fresh herbs if desired.",
    "Ensure poultry is cooked to an internal temperature of 74°C / 165°F (juices run clear, no pink remaining) before serving."
  ],
