      "amount": "1 teaspoon"
    },
    {
      "name": "coriander",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "water",
      "amount": "2 cups"
    }
  ],
  "instructions": [
    "Heat the olive oil in the pressure cooker over medium heat.",
    "Add the chopped onion and cook until it is translucent and starting to brown.",
    "Add the minced garlic and cook for 1 minute, stirring constantly to prevent burning.",
    "Add the lamb pieces and cook until they are browned on all sides.",
    "Add the cumin, coriander, salt, and black pepper, and stir to combine.",
    "Add the white sauerkraut and water, and stir to combine.",
    "Close the pressure cooker and bring to high pressure, then cook for 30 minutes.",
    "Let the pressure release naturally, then serve hot."
  ],
