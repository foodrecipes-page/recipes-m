      "name": "baby pak koi",
      "amount": "1 pound",
      "notes": "fresh"
    },
    {
      "name": "garlic",
      "amount": "3 cloves"
    },
    {
      "name": "lardons",
      "amount": "1/2 cup"
    },
    {
      "name": "low-sodium soy sauce",
      "amount": "1/4 cup"
    },
    {
      "name": "brown sugar",
      "amount": "2 tablespoons"
    },
    {
      "name": "green onions",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "bamboo skewers",
      "amount": "10"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Preheat grill to 400 degrees Fahrenheit.",
    "In a blender, puree garlic, low-sodium soy sauce, and brown sugar to make the garlicky sauce.",
    "Render lardons in a pan over medium heat until crispy.",
    "Thread baby pak koi onto bamboo skewers, leaving a small space between each piece.",
    "Brush the garlicky sauce onto both sides of the pak koi.",
    "Grill the skewers for 8 minutes, turning occasionally.",
    "Sprinkle crispy lardons and chopped green onions over the skewers during the last minute of grilling.",
    "Serve the skewers hot, garnished with additional green onions if desired."
  ],
