      "amount": "1 teaspoon"
    },
    {
      "name": "cayenne pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 300 degrees Fahrenheit.",
    "Heat the infuse oil in a large Dutch oven over medium high heat.",
    "Add the lamb pieces and cook until browned on all sides, about 5 minutes.",
    "Add the onion, garlic, and ginger to the pot and cook until the onion is translucent.",
    "Add the colatura, cumin, coriander, cayenne pepper, salt, and black pepper to the pot and stir to combine.",
    "Cover the pot and transfer it to the preheated oven.",
    "Cook the tagine for 2 1/2 hours, or until the lamb is tender and falling apart.",
    "Remove the pot from the oven and let it cool slightly before serving."
  ],
