      "notes": "cut into 2 inch pieces"
    },
    {
      "name": "pecan nuts",
      "amount": "1/2 cup",
      "notes": "chopped"
    },
    {
      "name": "lardons",
      "amount": "6 slices",
      "notes": "rendered"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
