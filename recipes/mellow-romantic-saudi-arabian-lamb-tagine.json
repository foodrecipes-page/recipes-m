      "amount": "2 inches",
      "notes": "grated"
    },
    {
      "name": "red wine",
      "amount": "1 cup",
      "notes": "dry"
    },
    {
      "name": "beef broth",
      "amount": "2 cups",
      "notes": "low sodium"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons",
      "notes": "extra virgin"
    },
    {
      "name": "cumin",
      "amount": "1 teaspoon",
      "notes": "ground"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large Dutch oven over medium heat.",
    "Add the lardons and cook until crispy, then remove from pot.",
    "Add the onion, garlic, and ginger to the pot and cook until the onion is translucent.",
    "Add the lamb to the pot and cook until browned on all sides.",
    "Add the red wine, beef broth, and cumin to the pot, then bring to a boil.",
    "Reduce the heat to low and simmer, covered, for 2.5 hours.",
    "Stir in the chopped pecan nuts and cook for an additional 30 minutes.",
    "Season with salt and pepper to taste, then serve hot."
  ],
