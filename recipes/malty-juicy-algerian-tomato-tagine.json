      "amount": "1/2 cup"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "malt vinegar",
      "amount": "2 tablespoons"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large saucepan over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and cook for an additional 1 minute.",
    "Stir in the crushed tomatoes, malt vinegar, salt, and black pepper.",
    "Bring the mixture to a simmer and cook for 20 minutes, stirring occasionally.",
    "Stir in the mayonnaise and cook for an additional 2 minutes.",
    "Taste and adjust the seasoning as needed.",
    "Serve the tagine hot, garnished with chopped fresh parsley."
  ],
