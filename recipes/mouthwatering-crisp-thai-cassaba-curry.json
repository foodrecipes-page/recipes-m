      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "water",
      "amount": "1 cup"
    }
  ],
  "instructions": [
    "Heat the coconut oil in a dolsot stone bowl over medium heat.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the minced garlic and cook for 1 minute.",
    "Add the Thai red curry paste and cook for 1 minute, stirring constantly.",
    "Add the cubed cassaba, fish sauce, brown sugar, salt, and black pepper, and stir to combine.",
    "Add the water and bring the mixture to a boil.",
    "Reduce the heat to low and simmer, covered, for 20 minutes, or until the cassaba is tender.",
    "Serve the curry hot, garnished with chopped fresh cilantro if desired."
  ],
