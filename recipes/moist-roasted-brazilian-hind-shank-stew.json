{
  "title": "Moist Roasted Brazilian Hind Shank Stew",
  "description": "A hearty, winey Brazilian stew featuring hind shank, roasted to perfection in a tandoor, served in a scallop shell, with anti-inflammatory friendly ingredients, perfect for a lazy Sunday",
  "cuisine": "Brazilian",
  "diet": [
    "gluten-free",
    "dairy-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "hind shank",
      "amount": "2 pounds",
      "notes": "bone-in, skin removed"
    },
    {
      "name": "red wine",
      "amount": "1 cup"
    },
    {
      "name": "coconut oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "turmeric",
      "amount": "1 teaspoon"
    },
    {
      "name": "ginger",
      "amount": "1 teaspoon",
      "notes": "grated"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "sea salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "scalloped potatoes",
      "amount": "2 cups",
      "notes": "thinly sliced"
    },
    {
      "name": "fresh cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the tandoor to 400 degrees Fahrenheit",
    "Season the hind shank with turmeric, ginger, black pepper, and sea salt",
    "Heat the coconut oil in the tandoor and sear the hind shank until browned on all sides",
    "Add the red wine to the tandoor and bring to a boil",
    "Cover the tandoor and roast the hind shank for 2 hours, or until tender",
    "Add the scalloped potatoes to the tandoor and continue to roast for an additional 30 minutes",
    "Stir in the chopped cilantro and serve the stew in scallop shells"
  ],
