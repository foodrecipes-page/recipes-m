{
  "title": "Minty Australian Toor Dal Stew",
  "description": "A hearty, grassy stew of toor dal cooked slowly with fresh mint, tomatoes, and coconut milk, perfect for a solo dinner.",
  "cuisine": "Australian",
  "diet": [
    "kosher-friendly"
  ],
  "meal": "dinner",
