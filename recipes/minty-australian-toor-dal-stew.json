    {
      "name": "Toor dal (red lentils)",
      "amount": "200g",
      "notes": "dried"
    },
    {
      "name": "Fresh mint leaves",
      "amount": "30g",
      "notes": "chopped"
    },
    {
      "name": "Onion",
      "amount": "1 medium",
      "notes": "diced"
    },
    {
      "name": "Garlic",
      "amount": "4 cloves",
      "notes": "minced"
    },
    {
      "name": "Fresh ginger",
      "amount": "1 inch",
      "notes": "grated"
    },
    {
      "name": "Cherry tomatoes",
