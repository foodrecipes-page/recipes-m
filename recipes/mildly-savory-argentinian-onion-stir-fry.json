      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "grass fed beef",
      "amount": "1 pound",
      "notes": "sliced into thin strips"
    },
    {
      "name": "chimichurri sauce",
      "amount": "1/4 cup"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large skillet over medium-high heat.",
    "Add the sliced onion and cook until it is translucent and starting to caramelize.",
    "Add the minced garlic and cook for an additional minute.",
    "Add the sliced grass fed beef and cook until it is browned and cooked through.",
    "Add the chimichurri sauce and stir to combine.",
    "Season with salt and black pepper to taste.",
    "Serve the stir fry hot, garnished with fresh parsley or oregano if desired."
  ],
