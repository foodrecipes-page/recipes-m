      "name": "serrano ham",
      "amount": "8 ounces",
      "notes": "diced"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "mitmita",
      "amount": "1 teaspoon",
      "notes": "Ethiopian spice blend"
    },
    {
      "name": "niter kibbeh",
      "amount": "2 tablespoons",
      "notes": "Ethiopian clarified butter"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon",
      "notes": "or to taste"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon",
      "notes": "or to taste"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons",
      "notes": "freshly squeezed"
    }
  ],
  "instructions": [
    "Heat the niter kibbeh in a large skillet over medium heat.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the minced garlic and cook for an additional minute.",
    "Add the diced serrano ham and cook until it is lightly browned.",
    "Add the mitmita, salt, and black pepper, and stir to combine.",
    "Squeeze the lemon juice over the top of the ham mixture and stir to combine.",
    "Reduce the heat to low and simmer the mixture for 10 minutes.",
    "Serve the gored gored hot, garnished with chopped fresh herbs if desired."
  ],
