      "notes": "canned, drained, and rinsed"
    },
    {
      "name": "fish sauce",
      "amount": "2 tablespoons"
    },
    {
      "name": "lacquer glaze",
      "amount": "1 tablespoon"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "smoked paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit.",
    "In a large bowl, whisk together the fish sauce, lacquer glaze, olive oil, garlic, lemon juice, smoked paprika, salt, and black pepper.",
    "Add the chickpeas to the bowl and toss to coat with the sauce.",
    "Spread the chickpeas on a baking sheet lined with parchment paper.",
    "Bake the chickpeas in the preheated oven for 20 minutes, or until they are lightly browned and crispy.",
    "Remove the chickpeas from the oven and let them cool to room temperature.",
    "Serve the chickpeas warm or at room temperature, garnished with fresh parsley or dill if desired."
  ],
