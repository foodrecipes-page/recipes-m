{
  "title": "Mildly Smoky Greek Chickpeas Revithia",
  "description": "A fresh and juicy post-workout Greek dish featuring chickpeas in a mildly smoky flavor, made with fish sauce and a lacquer glaze, and is satvik friendly.",
  "cuisine": "Greek",
  "diet": [
    "gluten-free"
  ],
