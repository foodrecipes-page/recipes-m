  "ingredients": [
    {
      "name": "canned tomatoes",
      "amount": "1 can",
      "notes": "14.5 oz"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp"
    },
    {
      "name": "soy sauce",
      "amount": "1 tbsp"
    },
    {
      "name": "yuzu juice",
      "amount": "1 tbsp"
    },
    {
      "name": "garlic",
      "amount": "3 cloves"
    },
    {
      "name": "ginger",
      "amount": "1 inch"
    },
    {
      "name": "green onions",
      "amount": "1/4 cup"
    },
    {
      "name": "sesame seeds",
      "amount": "1 tsp"
    },
    {
      "name": "salt",
      "amount": "1/2 tsp"
    },
    {
      "name": "black pepper",
      "amount": "1/4 tsp"
    }
  ],
  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit",
    "In a large bowl, whisk together olive oil, soy sauce, yuzu juice, salt, and black pepper",
    "Add the canned tomatoes, garlic, and ginger to the bowl and stir to combine",
    "Transfer the mixture to a mason jar and top with green onions and sesame seeds",
    "Roast in the preheated oven for 20 minutes",
    "Remove from the oven and let cool for 5 minutes",
    "Serve hot and enjoy",
    "Garnish with additional green onions and sesame seeds if desired",
    "Store any leftovers in the refrigerator for up to 3 days"
  ],
