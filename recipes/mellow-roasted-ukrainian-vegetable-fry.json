    {
      "name": "carrots",
      "amount": "2-3 medium-sized",
      "notes": "peeled, cut into 1-inch sticks"
    },
    {
      "name": "zucchini",
      "amount": "1-2 medium-sized",
      "notes": "cut into 1-inch slices"
    },
    {
      "name": "onion",
      "amount": "1 medium-sized",
      "notes": "cut into 1-inch wedges"
    },
    {
