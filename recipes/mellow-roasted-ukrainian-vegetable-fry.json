      "notes": "chopped"
    },
    {
      "name": "sunflower oil",
      "amount": "1/4 cup",
      "notes": "for roasting"
    },
    {
      "name": "salt",
      "amount": "to taste",
      "notes": "optional"
    }
  ],
  "instructions": [
    "preheat the oven to 425f (220c).",
    "toss the potatoes, carrots, and zucchini with 2 tablespoons of sunflower oil, salt, and chopped parsley and dill on a wooden board.",
    "spread the vegetables in a single layer and roast for 20 minutes.",
    "meanwhile, heat the remaining 2 tablespoons of sunflower oil in a pan over medium heat.",
    "add the onion and garlic and saut\u00048 until the onion is lightly browned.",
    "add the roasted vegetables to the pan and stir to combine.",
    "serve hot, garnished with additional parsley and dill if desired.",
    "do not overcrowd the pan, cook in batches if necessary.",
    "be gentle when stirring to avoid breaking the vegetables.",
    "cook the vegetables over medium heat to prevent burning.",
    "adjust the seasoning with salt to taste, if desired."
  ],
