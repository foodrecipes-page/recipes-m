{
  "title": "Molten Indian Fish Curry",
  "description": "A garlicky and molten Indian dish featuring fish stock, deep-fry-tod, and pescatarian-friendly ingredients, served on a comal.",
  "cuisine": "Indian",
  "diet": [
    "pescatarian"
  ],
