{
  "title": "Mouthwatering Smoky Brazilian Chicken Skewers",
  "description": "A smoky and creamy Brazilian dish featuring doenjang, perfect for showing off at your next dinner party, and is fodmap friendly.",
  "cuisine": "Brazilian",
  "diet": [
    "gluten-free",
    "low-carb"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "chicken breast",
      "amount": "1 1/2 pounds",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "doenjang",
      "amount": "2 tablespoons"
    },
    {
      "name": "coconut milk",
      "amount": "1/2 cup"
    },
    {
      "name": "smoked paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "garlic powder",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "bamboo skewers",
      "amount": "10",
      "notes": "soaked in water for 30 minutes"
    },
    {
      "name": "fresh cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat grill to 400 degrees Fahrenheit.",
    "In a large bowl, whisk together doenjang, coconut milk, smoked paprika, garlic powder, salt, and black pepper.",
    "Add the chicken to the bowl and toss to coat with the marinade.",
    "Thread the marinated chicken onto the bamboo skewers, leaving a small space between each piece.",
    "Grill the skewers for 10-12 minutes, turning occasionally, until the chicken is cooked through.",
    "Brush the skewers with additional coconut milk during the last 2 minutes of grilling.",
    "Garnish with chopped fresh cilantro and serve immediately.",
    "Let the skewers rest for 5 minutes before serving."
  ],
