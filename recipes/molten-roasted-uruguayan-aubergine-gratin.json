  "instructions": [
    "preheat the oven to 180\u00120c",
    "brush the copper pot with olive oil and set aside",
    "roast the aubergine in the oven for 20 minutes, or until tender",
    "heat the onion and garlic in a pan over medium heat until softened",
    "add the tadka spice mix and cook for 1 minute",
    "stir in the tomato paste and cook for a further minute",
    "add the stock and bring to a simmer",
    "transfer the aubergine to the copper pot and spoon over the tadka sauce",
    "top with grated queso fresco and place in the oven for 10 minutes, or until melted"
