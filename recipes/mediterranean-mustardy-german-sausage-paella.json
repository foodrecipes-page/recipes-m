    {
      "name": "confit tomato",
      "amount": "1 cup",
      "notes": "homemade or store-bought"
    },
    {
      "name": "mustard",
      "amount": "2 tablespoons",
      "notes": "whole-grain or Dijon"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "artichoke hearts",
      "amount": "1 can",
      "notes": "drained and chopped"
    },
    {
      "name": "chicken broth",
      "amount": "2 cups"
    },
    {
      "name": "saffron threads",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "smoked paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt and pepper",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large paella pan over medium-high heat.",
    "Add the chopped onion and cook until translucent, about 5 minutes.",
    "Add the minced garlic and cook for an additional minute, until fragrant.",
    "Add the German sausage and cook until browned, about 5 minutes.",
    "Add the confit tomato, mustard, artichoke hearts, chicken broth, saffron threads, and smoked paprika to the paella pan.",
    "Stir to combine and bring the mixture to a simmer.",
    "Reduce the heat to low and cook, covered, for 20 minutes, or until the sausage is cooked through and the liquid has been absorbed.",
    "Season with salt and pepper to taste.",
    "Serve hot, garnished with fresh parsley or thyme, if desired."
  ],
