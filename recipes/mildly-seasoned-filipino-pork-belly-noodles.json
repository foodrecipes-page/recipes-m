      "name": "pork belly",
      "amount": "1 pound",
      "notes": "sliced into thin strips"
    },
    {
      "name": "noodles",
      "amount": "8 ounces",
      "notes": "rice noodles"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 inch",
      "notes": "grated"
    },
    {
      "name": "patis",
      "amount": "1 tablespoon",
      "notes": "fish sauce"
    },
    {
      "name": "black pepper",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "scallions",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "calamansi",
      "amount": "2 tablespoons",
      "notes": "juice"
    }
  ],
  "instructions": [
    "Heat the oil in a large pan over medium heat.",
    "Add the sliced pork belly and cook until browned, about 5 minutes.",
    "Add the chopped onion, minced garlic, and grated ginger to the pan and cook until the onion is translucent.",
    "Add the patis, black pepper, and salt to the pan and stir to combine.",
    "Add the noodles to the pan and cook, stirring constantly, until they are al dente.",
    "Stir in the chopped scallions and calamansi juice.",
    "Serve the noodles hot, topped with additional scallions and calamansi juice if desired.",
    "Garnish with sliced green onions and serve immediately."
  ],
