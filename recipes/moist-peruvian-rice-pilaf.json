      "notes": "toasted"
    },
    {
      "name": "fresh cilantro",
      "amount": "1/4 cup",
      "notes": "chopped, for garnish"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "black pepper",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "heat sesame seed oil in a medium saucepan over medium heat",
    "add chopped onion and cook until translucent, about 5 minutes",
    "add minced garlic and cook for 1 minute, until fragrant",
    "add ground saffron and cook for 1 minute, until fragrant",
    "add fry-grind-rice-khao-khua and cook for 2-3 minutes, until lightly toasted",
    "add chicken broth, soy sauce (if using), salt, and black pepper",
    "bring to a boil, then reduce heat to low, cover, and simmer for 18-20 minutes",
    "fluff pilaf with a fork and stir in toasted sesame seeds",
    "garnish with chopped fresh cilantro and serve hot"
  ],
