  "ingredients": [
    {
      "name": "boneless chicken breast",
      "amount": "1 pound",
      "notes": "cut into bite sized pieces"
    },
    {
      "name": "panang paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "coconut milk",
      "amount": "1 can"
    },
    {
      "name": "olive oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 inch",
      "notes": "grated"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large pan over medium heat.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the minced garlic and grated ginger and cook for 1 minute.",
    "Add the chicken to the pan and cook until it is browned on all sides.",
    "Add the panang paste to the pan and cook for 1 minute.",
    "Pour in the coconut milk and bring the mixture to a simmer.",
    "Reduce the heat to low and let the curry simmer for 10 minutes.",
    "Season the curry with salt and black pepper to taste.",
    "Serve the curry hot over rice or with naan bread."
  ],
