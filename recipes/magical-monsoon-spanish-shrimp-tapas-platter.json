  "ingredients": [
    {
      "name": "shrimp",
      "amount": "1 pound",
      "notes": "peeled and deveined"
    },
    {
      "name": "yuzu kosho",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 tablespoon",
      "notes": "grated"
    },
    {
      "name": "turmeric",
      "amount": "1 teaspoon"
    },
    {
      "name": "paprika",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large skillet over medium high heat.",
    "Add the garlic and ginger and cook for 1 minute until fragrant.",
    "Add the shrimp and cook for 2 minutes per side until pink and fully cooked.",
    "In a small bowl, mix together the yuzu kosho, turmeric, paprika, salt, and black pepper.",
    "Add the yuzu kosho mixture to the skillet and stir to combine.",
    "Cook for an additional 1 minute until the shrimp are fully coated.",
    "Remove the skillet from the heat and stir in the lemon juice.",
    "Serve the shrimp hot, garnished with chopped fresh parsley or cilantro if desired."
  ],
