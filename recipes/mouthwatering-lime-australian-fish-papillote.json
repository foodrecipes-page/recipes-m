  "ingredients": [
    {
      "name": "Australian fish fillets",
      "amount": "4 fillets",
      "notes": "such as barramundi or snapper"
    },
    {
      "name": "fresh lime juice",
      "amount": "1/2 cup"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "chopped fresh parsley",
      "amount": "1/4 cup"
    },
    {
      "name": "chopped fresh dill",
      "amount": "1/4 cup"
    },
    {
      "name": "minced garlic",
      "amount": "2 cloves"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "pepper",
      "amount": "to taste"
    },
    {
      "name": "agave leaves",
      "amount": "4 leaves",
      "notes": "for wrapping"
    }
  ],
  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit.",
    "In a small bowl, whisk together lime juice, olive oil, parsley, dill, garlic, salt, and pepper.",
    "Place a fish fillet in the center of each agave leaf.",
    "Brush the lime juice mixture evenly over both sides of the fish fillets.",
    "Fold the agave leaves over the fish to form a papillote, and secure with kitchen twine if necessary.",
    "Place the papillotes on a baking sheet lined with parchment paper.",
    "Bake for 12 minutes or until the fish is cooked through and flakes easily with a fork.",
    "Serve immediately, garnished with additional parsley and lime wedges if desired."
  ],
