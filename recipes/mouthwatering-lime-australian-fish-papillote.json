{
  "title": "Mouthwatering Lime Australian Fish Papillote",
  "description": "A low-calorie, herbal, and fluffy Australian dish featuring lime and papillote, cooked in an agave leaf vessel.",
  "cuisine": "Australian",
  "diet": [
    "low-calorie",
    "gluten-free"
  ],
