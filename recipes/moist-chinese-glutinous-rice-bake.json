      "name": "glutinous rice",
      "amount": "1 cup"
    },
    {
      "name": "brown sugar",
      "amount": "2 tablespoons"
    },
    {
      "name": "black treacle (dark molasses)",
      "amount": "1 tablespoon"
    },
    {
      "name": "vanilla extract",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "cooking oil",
      "amount": "1/4 cup"
    },
    {
      "name": "salt",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Combine brown sugar, black treacle, and vanilla extract in a large bowl.",
    "Add cooking oil to the mixture and stir until well combined.",
    "Gradually add glutinous rice while stirring constantly with a spoon or spatula.",
    "Transfer the mixture into a greased baking dish.",
    "Bake at 350°F (175°C) for 25 minutes, or until the rice is fully cooked and fluffy."
