  "instructions": [
    "heat oil in a large pot over medium-high heat.",
    "add onion and garlic and sauté until softened, about 5 minutes.",
    "add red bell pepper and ají amarillo and sauté for another 5 minutes.",
    "add shrimp and cook until pink, about 2-3 minutes per side.",
    "add fish stock, mustard, smoked paprika, salt, and pepper.",
    "bring to a boil, then reduce heat to low and simmer for 5 minutes.",
    "stir in heavy cream and cook for another 2-3 minutes.",
