{
  "title": "Mildly Sour Ethiopian Chicken Doro Wot",
  "description": "A sour, creamy, and diabetic-friendly Ethiopian dish featuring seeds and grilled chicken, perfect for a post-workout meal.",
  "cuisine": "Ethiopian",
  "diet": [
    "diabetic-friendly",
