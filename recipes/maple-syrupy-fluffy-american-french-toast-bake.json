{
  "title": "Maple Syrupy Fluffy American French-toast Bake",
  "description": "A twist on classic French toast, with a fluffy interior and a sweet maple syrup topping, perfect for a lazy Sunday morning.",
  "cuisine": "American",
  "diet": [
    "low-fat"
  ],
  "meal": "breakfast",
  "ingredients": [
    {
      "name": "Large eggs",
      "amount": "3"
    },
    {
      "name": "Milk",
      "amount": "1 cup"
    },
    {
      "name": "Granulated sugar",
      "amount": "1/2 cup"
    },
    {
      "name": "Salt",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "Cinnamon",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "Vanilla extract",
      "amount": "1 teaspoon"
    },
    {
      "name": "Bread ( Challah or Brioche)",
      "amount": "4 slices"
    },
    {
      "name": "Maple syrup",
      "amount": "1/4 cup"
    },
    {
      "name": "Unsalted butter",
      "amount": "2 tablespoons"
    },
    {
      "name": "Bonito shavings",
      "amount": "1/4 cup"
    },
    {
      "name": "Fresh thyme",
      "amount": "1 tablespoon"
    }
  ],
  "instructions": [
    "Preheat oven to 375°F (190°C).",
    "In a large bowl, whisk together eggs, milk, sugar, salt, cinnamon, and vanilla extract until well combined.",
    "Add the bread slices to the bowl and toss to coat evenly.",
    "Transfer the bread mixture to a 9x13-inch baking dish.",
    "Dot the top of the bread with unsalted butter.",
    "Bake for 20 minutes or until golden brown.",
    "While the bread is baking, mix together maple syrup and bonito shavings in a small bowl.",
    "Once the bread is done, remove it from the oven and let it cool for 2 minutes.",
    "Brush the maple syrup-bonito mixture over the top of the bread.",
    "Sprinkle with fresh thyme and serve warm."
  ],
