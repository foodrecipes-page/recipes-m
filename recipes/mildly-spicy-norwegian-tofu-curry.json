{
  "title": "Mildly Spicy Norwegian Tofu Curry",
  "description": "A rich and pillowy Norwegian dish featuring green curry paste and ferment jang, perfect for a post-workout meal",
  "cuisine": "Norwegian",
  "diet": [
    "plant-based",
    "vegetarian"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "extra firm tofu",
      "amount": "1 block",
      "notes": "drained and cut into cubes"
    },
    {
      "name": "green curry paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "ferment jang",
      "amount": "1 tablespoon"
    },
    {
      "name": "coconut milk",
      "amount": "1 can"
    },
    {
      "name": "norwegian potato",
      "amount": "2 medium",
      "notes": "peeled and diced"
    },
    {
      "name": "carrot",
      "amount": "1 large",
      "notes": "peeled and grated"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large pan over medium heat",
    "Add the chopped onion and cook until softened",
    "Add the grated carrot and cook for an additional 2 minutes",
    "Add the green curry paste and ferment jang, stirring constantly for 1 minute",
    "Add the diced potato, salt, and black pepper, stirring to combine",
    "Add the coconut milk and bring the mixture to a simmer",
    "Reduce the heat to low and let cook for 20 minutes, or until the potato is tender",
    "Add the cubed tofu and stir to combine",
    "Let cook for an additional 5 minutes, or until the tofu is heated through"
  ],
