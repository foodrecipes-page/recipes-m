    {
      "name": "frozen mixed berries",
      "amount": "300g",
      "notes": "thawed and drained"
    },
    {
      "name": "fresh mint leaves",
      "amount": "2 tbsp",
      "notes": "chopped"
    },
    {
      "name": "honey",
      "amount": "1 tbsp",
      "notes": "optional sweetener"
    },
    {
      "name": "lemon zest",
      "amount": "1 tsp",
      "notes": "freshly grated"
    }
  ],
  "instructions": [
    "Preheat oven to 200°C.",
    "Unroll puff pastry onto parchment, trim edges, and press into a tart pan.",
    "Bake pastry for 10 minutes until lightly golden.",
    "While pastry bakes, thaw berries, drain, and mix with mint, honey, and lemon zest.",
    "Remove dough from oven and spread berry filling evenly over crust.",
    "Bake for an additional 5 minutes until berries caramelize.",
    "Let cool 5 minutes, dust with powdered sugar, slice, and serve."
