    },
    {
      "name": "light brown sugar substitute",
      "amount": "2 tablespoons",
      "notes": ""
    },
    {
      "name": "unsalted butter",
      "amount": "2 tablespoons",
      "notes": "melted"
    }
  ],
  "instructions": [
    "preheat the oven to 375f (190c).",
    "in a large mixing bowl, combine the yautia, coconut milk, cocoa powder, tandoor powder, cinnamon, and nutmeg. mix until well combined.",
    "crack in the egg and mix until fully incorporated.",
    "add the sugar substitute and mix until smooth.",
    "pour the mixture into a greased 9x9-inch baking dish.",
    "dot the top with melted butter.",
    "bake for 25 minutes, or until the edges are set and the center is slightly jiggly.",
    "remove from the oven and let cool for 5 minutes before serving."
