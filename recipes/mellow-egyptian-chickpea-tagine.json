{
  "title": "Mellow Egyptian Chickpea Tagine",
  "description": "A herbal and creamy Egyptian dish featuring chickpea flour, bonito shave, and ayurvedic sattvic friendly ingredients, perfect for a lazy Sunday",
  "cuisine": "Egyptian",
  "diet": [],
