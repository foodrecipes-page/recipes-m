      "name": "fenugreek leaves",
      "amount": "1 cup",
      "notes": "fresh or frozen"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "beurre-monte",
      "amount": "2 tablespoons"
    },
    {
      "name": "curry powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "turmeric",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "coconut milk",
      "amount": "1 can"
    },
    {
      "name": "tomato puree",
      "amount": "1/2 cup"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Heat the beurre-monte in a large pan over medium heat",
    "Add the chopped onion and cook until softened, about 5 minutes",
    "Add the minced garlic and cook for an additional minute",
    "Stir in the curry powder and turmeric and cook for 1 minute",
    "Add the fenugreek leaves and cook until wilted, about 3 minutes",
    "Pour in the coconut milk and tomato puree, and stir to combine",
    "Bring the mixture to a simmer and cook for 10 minutes",
    "Season with salt and black pepper to taste",
    "Serve hot over rice or with naan bread"
  ],
