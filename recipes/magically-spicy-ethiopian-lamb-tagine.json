  "ingredients": [
    {
      "name": "lamb shoulder",
      "amount": "1.5 pounds",
      "notes": "cut into 1.5 inch cubes"
    },
    {
      "name": "lemongrass",
      "amount": "2 stalks",
      "notes": "bruised"
    },
    {
      "name": "ginger",
      "amount": "2 inches",
      "notes": "grated"
    },
    {
      "name": "berbere spice",
      "amount": "2 tablespoons"
    },
    {
      "name": "coriander",
      "amount": "1 teaspoon"
    },
    {
      "name": "cumin",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "0.5 teaspoon"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "chicken broth",
      "amount": "1 cup"
    }
  ],
  "instructions": [
    "Heat the olive oil in the iron teppan over medium-high heat.",
    "Add the lamb cubes and cook until browned on all sides, about 5 minutes.",
    "Add the bruised lemongrass, grated ginger, berbere spice, coriander, cumin, salt, and black pepper, and cook for 1 minute.",
    "Pour in the chicken broth and bring the mixture to a boil.",
    "Reduce the heat to low, cover the teppan with a lid, and simmer the tagine for 1.5 hours, or until the lamb is tender.",
    "Remove the lemongrass stalks and serve the tagine hot.",
    "Garnish with fresh cilantro or scallions, if desired.",
    "Serve over rice or with crusty bread."
  ],
