{
  "title": "Magically Spicy Ethiopian Lamb Tagine",
  "description": "A spicy and snappy Ethiopian dish featuring lemongrass, cooked to perfection in a tagine on an iron teppan, perfect for midnight cravings, and friendly to those who avoid onion and garlic.",
  "cuisine": "Ethiopian",
  "diet": [
    "gluten-free",
    "no-onion",
    "no-garlic"
  ],
