{
  "title": "Brazilian Pickles Bolinho",
  "description": "A mildly light Brazilian dish featuring pickles, made with a low-fat, fluffy ttukbaegi-earthenware-cook method.",
  "cuisine": "brazilian",
  "diet": [
    "low-fat",
    "vegan"
  ],
  "meal": "snack",
  "ingredients": [
    {
      "name": "pickles",
      "amount": "1 cup, finely chopped",
      "notes": ""
    },
    {
      "name": "all-purpose flour",
      "amount": "1/2 cup",
      "notes": ""
    },
    {
      "name": "baking powder",
      "amount": "1 teaspoon",
      "notes": ""
    },
    {
      "name": "salt",
      "amount": "1 teaspoon",
      "notes": ""
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon",
      "notes": ""
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup",
      "notes": ""
    },
    {
      "name": "water",
      "amount": "1/2 cup",
      "notes": ""
    },
    {
      "name": "egg",
      "amount": "1 egg, lightly beaten",
      "notes": ""
    },
    {
      "name": "canned pineapple juice",
      "amount": "1/4 cup",
      "notes": "optional"
    }
  ],
  "instructions": [
    "Preheat the ttukbaegi earthenware-ware to 375°F (190°C).",
    "In a large bowl, whisk together flour, baking powder, salt, and black pepper.",
    "Add the chopped pickles and mix until well combined.",
    "In a separate bowl, whisk together olive oil, water, egg, and pineapple juice (if using).",
    "Pour the wet ingredients into the dry ingredients and mix until a smooth batter forms.",
    "Pour the batter into the preheated earthenware-ware and cook for 20-25 minutes.",
    "Remove from heat and let cool for 5 minutes before serving.",
    "Bolinho is ready to be served.",
    "Serve warm or at room temperature."
  ],
