  "instructions": [
    "preheat the tandoor to 200\u000730",
    "mix together soy sauce, rice vinegar, honey, sesame oil, garam masala, cumin, coriander, salt, and black pepper in a small bowl",
    "rub the lamb leg with the spice mixture, making sure to coat it evenly",
    "heat 1 tbsp of ghee in the tandoor and sear the lamb leg on all sides until browned",
    "remove the lamb leg from the tandoor and set it aside",
    "add the remaining 1 tbsp of ghee to the tandoor and stir in the cilantro",
    "return the lamb leg to the tandoor and baste it with the cilantro-ghee mixture every 10 minutes for 30 minutes",
    "remove the lamb leg from the tandoor and let it rest for 5 minutes before slicing it thinly"
  ],
