{
  "title": "Mellow Irish Beef Tagine",
  "description": "A citrusy and chewy twist on traditional Irish beef stew, featuring red wine jelly and a tagine-cook method.",
  "cuisine": "Irish",
  "diet": [
    "low-sodium"
  ],
  "meal": "dinner",
