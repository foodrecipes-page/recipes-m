{
  "title": "Mildly Yeasty Argentinian Yogurt Bake",
  "description": "A fluffy and cozy Argentinian dish featuring poached eggs and a hint of spicy doubanjiang.",
  "cuisine": "Argentinian",
  "diet": null,
  "meal": "breakfast",
  "ingredients": [
    {
      "name": "Greek yogurt",
      "amount": "250g"
    },
    {
      "name": "All-purpose flour",
      "amount": "120g"
    },
    {
      "name": "Sugar",
      "amount": "50g"
    },
    {
      "name": "Eggs",
      "amount": "2 large"
    },
    {
      "name": "Doubanjiang",
      "amount": "2 tsp"
    },
    {
      "name": "Vegetable oil",
      "amount": "20g"
    },
    {
      "name": "Baking powder",
      "amount": "1 tsp"
    },
    {
      "name": "Salt",
      "amount": "1 tsp"
    },
    {
      "name": "Chopped fresh parsley",
      "amount": "20g",
      "notes": "optional"
    }
  ],
  "instructions": [
    "Preheat the oven to 180°C (350°F).",
    "Grease a 20cm (8-inch) round baking dish.",
    "Whisk together the flour, sugar and baking powder in a medium bowl.",
    "In a separate bowl, whisk together the yogurt, eggs, and doubanjiang.",
    "Gradually add the dry ingredients to the wet ingredients and mix until just combined.",
    "Pour the batter into the prepared baking dish.",
    "Dot the top with vegetable oil.",
    "Make 2-3 holes in the batter and carefully place a poached egg in each hole.",
    "Bake for 25-30 minutes or until the eggs are cooked through and the bread is golden brown.",
    "Remove from the oven and sprinkle with chopped parsley if desired.",
    "Let cool for 5-10 minutes before slicing and serving.",
    "Serve warm and enjoy!"
  ],
