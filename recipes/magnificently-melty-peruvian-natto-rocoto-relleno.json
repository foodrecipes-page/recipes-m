      "name": "natto",
      "amount": "1 cup",
      "notes": "fermented soybeans"
    },
    {
      "name": "rocoto peppers",
      "amount": "4 large",
      "notes": "roasted and peeled"
    },
    {
      "name": "queso fresco",
      "amount": "1 cup",
      "notes": "crumbly cheese"
    },
    {
      "name": "whisked eggs",
      "amount": "2 large",
      "notes": "for binding"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "onion",
      "amount": "1 small",
      "notes": "finely chopped"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit",
    "Cut the tops off the rocoto peppers and remove the seeds and membranes",
    "In a bowl, whisk together the eggs, natto, garlic, onion, salt, and black pepper",
    "Stuff each rocoto pepper with the natto mixture, filling to the top",
    "Place the stuffed peppers in a tagine pot, cover with foil, and bake for 25 minutes",
    "Remove the foil, top each pepper with queso fresco, and return to the oven for an additional 10 minutes, or until the cheese is melted and bubbly",
    "Remove the peppers from the oven and let cool for a few minutes",
    "Drizzle the peppers with olive oil and serve hot"
  ],
