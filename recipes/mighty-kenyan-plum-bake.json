  "ingredients": [
    {
      "name": "plum sauce",
      "amount": "1 cup",
      "notes": "homemade or store-bought"
    },
    {
      "name": "oats",
      "amount": "2 cups",
      "notes": "rolled or steel-cut"
    },
    {
      "name": "almond milk",
      "amount": "1 cup",
      "notes": "or other non-dairy milk"
    },
    {
      "name": "coconut oil",
      "amount": "1/4 cup",
      "notes": "melted"
    },
    {
      "name": "brown sugar",
      "amount": "1/2 cup",
      "notes": "or other sweetener"
    },
    {
      "name": "ginger",
      "amount": "1 tablespoon",
      "notes": "grated"
    },
    {
      "name": "cinnamon",
      "amount": "1 teaspoon",
      "notes": "ground"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon",
      "notes": "or to taste"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "In a large bowl, mix together the oats, almond milk, melted coconut oil, brown sugar, grated ginger, ground cinnamon, and salt.",
    "Stir in the plum sauce until well combined.",
    "Pour the mixture into a hot pot vessel or a 9x13 inch baking dish.",
    "Bake for 35-40 minutes or until the top is golden brown and the mixture is set.",
    "Remove from the oven and let cool for a few minutes.",
    "Serve warm, garnished with additional plum sauce if desired.",
    "Store leftovers in an airtight container in the refrigerator for up to 3 days."
  ],
