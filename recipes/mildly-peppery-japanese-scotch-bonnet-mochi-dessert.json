{
  "title": "Mildly Peppery Japanese Scotch Bonnet Mochi Dessert",
  "description": "A comforting Japanese dessert featuring scotch bonnet peppers and lardons-rendered mochi, perfect for a sweet treat.",
  "cuisine": "japanese",
  "diet": [
    "vegetarian"
  ],
