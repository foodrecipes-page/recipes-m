      "name": "Scotch Bonnet Peppers",
      "amount": "2",
      "notes": "seeded and finely chopped"
    },
    {
      "name": "Rice Flour",
      "amount": "1 cup",
      "notes": "for mochi"
    },
    {
      "name": "Water",
      "amount": "1/2 cup",
      "notes": "for mochi"
    },
    {
      "name": "Mochiko",
      "amount": "1/4 cup",
      "notes": "Japanese rice flour"
    },
    {
      "name": "Granulated Sugar",
      "amount": "1/2 cup",
      "notes": "for sweetness"
    },
    {
      "name": "Lardons",
      "amount": "1/4 cup",
      "notes": "rendered pork fat"
    },
    {
      "name": "Soy Milk",
      "amount": "1/2 cup",
      "notes": "low-fat milk alternative"
    },
    {
      "name": "Vanilla Extract",
      "amount": "1 tsp",
      "notes": "for flavor"
    },
    {
      "name": "Konnyaku Powder",
      "amount": "1 tsp",
      "notes": " Japanese potato starch"
    }
  ],
  "instructions": [
    "Combine scotch bonnet peppers, rice flour, mochiko, and soy milk in a bowl to create the mochi dough.",
    "Knead the dough for 5 minutes until smooth and pliable.",
    "Divide the dough into 8 equal pieces and shape each piece into a ball.",
    "Flatten each ball into a disk shape, about 1/4 inch thick.",
    "Heat the lardons-rendered fat in a pan over medium heat.",
    "Add the mochi disks to the pan and cook for 2-3 minutes on each side.",
    "Combine granulated sugar and konnyaku powder in a small bowl.",
    "Dust the cooked mochi disks with the sugar and konnyaku powder mixture.",
    "Serve warm with a drizzle of vanilla extract, if desired."
  ],
