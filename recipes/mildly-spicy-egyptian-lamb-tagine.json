      "notes": "boneless, cut into 1 inch pieces"
    },
    {
      "name": "manchego cheese",
      "amount": "1/2 cup",
      "notes": "crumbled"
    },
    {
      "name": "dates",
      "amount": "1/2 cup",
      "notes": "pitted"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
