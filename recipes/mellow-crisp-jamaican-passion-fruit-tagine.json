  "instructions": [
    "heat the coconut oil in a large clay tagine over medium heat",
    "add the crushed green cardamom pods and cook for 2 minutes",
    "add the passion fruit pulp and cook for 5 minutes, stirring occasionally",
    "add the garam masala powder, cinnamon powder, and black pepper, and stir to combine",
    "add the chopped fresh thyme and stir to combine",
    "pour in the coconut milk and bring the mixture to a simmer",
    "reduce the heat to low and cook for 10 minutes, stirring occasionally",
    "serve the tagine hot, garnished with fresh thyme and a dollop of coconut milk"
  ],
