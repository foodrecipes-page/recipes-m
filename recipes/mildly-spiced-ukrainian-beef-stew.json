      "name": "beef stew meat",
      "amount": "1.5 pounds",
      "notes": "cut into 1.5 inch cubes"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "carrots",
      "amount": "2 medium",
      "notes": "peeled and chopped"
    },
    {
      "name": "potatoes",
      "amount": "2 medium",
      "notes": "peeled and chopped"
    },
    {
      "name": "pomegranate molasses",
      "amount": "2 tablespoons"
    },
    {
      "name": "score-fat",
      "amount": "2 tablespoons",
      "notes": "or vegetable oil"
    },
    {
      "name": "dried thyme",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "0.5 teaspoon"
    },
    {
      "name": "beef broth",
      "amount": "2 cups"
    }
  ],
  "instructions": [
    "Heat the score-fat in a large Dutch oven over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the beef cubes and cook until browned on all sides, about 5 minutes.",
    "Add the chopped carrots and potatoes, and cook for an additional 2 minutes.",
    "Stir in the pomegranate molasses, dried thyme, salt, and black pepper.",
    "Pour in the beef broth and bring the mixture to a boil.",
    "Reduce the heat to low, cover, and simmer for 1.5 hours, or until the beef is tender.",
    "Serve hot, garnished with fresh herbs if desired."
  ],
