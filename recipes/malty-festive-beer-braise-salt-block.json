  "ingredients": [
    {
      "name": "1 lb boneless chuck roast",
      "amount": "1"
    },
    {
      "name": "2 medium carrots, thinly sliced",
      "amount": "2"
    },
    {
      "name": "2 stalks celery, finely chopped",
      "amount": "2"
    },
    {
      "name": "2 cloves garlic, minced",
      "amount": "2"
    },
    {
      "name": "6 oz pearl barley",
      "amount": "6"
    },
    {
      "name": "1 bottle of dark beer (12 oz)",
      "amount": "1"
    },
    {
      "name": "1 cup red wine",
      "amount": "1"
    },
    {
      "name": "4 sprigs fresh thyme",
      "amount": "4"
    },
    {
      "name": "4 bay leaves",
      "amount": "4"
    },
    {
      "name": "4 cloves garlic, whole",
      "amount": "4"
    },
    {
      "name": "1 tsp salt",
      "amount": "1"
    }
  ],
  "instructions": [
    "Preheat oven to 325 degrees F (160 degrees C).",
    "Combine carrots and celery in a pot with pearl barley.",
    "Add garlic, thyme, bay leaves, whole cloves, and wine. Bring to simmer over medium heat.",
    "Add dark beer and salt, bring back to simmer. Reduce by half.",
    "Place meat on top of the vegetables, season with pepper and rosemary.",
    "Transfer to a hot preheated salt block in oven. Let cook until tender (approximately 2 hours).",
    "Serve immediately."
  ],
