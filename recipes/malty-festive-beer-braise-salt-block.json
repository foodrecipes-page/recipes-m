{
  "title": "Malty-Festive Beer Braise Salt-Block",
  "description": "A no-onion-no-garlic-friendly malty and molten festive dish with a mirepoix-base, designed to be cooked in a salt-block for an Egyptian-inspired meal.",
  "cuisine": "Egyptian",
  "diet": null,
