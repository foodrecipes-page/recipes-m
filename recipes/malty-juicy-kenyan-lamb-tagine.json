      "amount": "1/4 cup"
    },
    {
      "name": "vanilla sugar",
      "amount": "2 tablespoons"
    },
    {
      "name": "water",
      "amount": "2 cups"
    },
    {
      "name": "flour",
      "amount": "2 tablespoons",
      "notes": "for thickening"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large clay or ceramic pot over medium heat.",
    "Add the onion and cook until softened, about 5 minutes.",
    "Add the garlic and ginger and cook for another minute.",
    "Add the lamb pieces and cook until browned on all sides, about 5 minutes.",
    "Add the cardamom pods, cinnamon stick, date syrup, and vanilla sugar. Stir to combine.",
    "Add the water and bring to a simmer.",
    "Reduce the heat to low and cook, covered, until the lamb is tender, about 1 1/2 hours.",
    "Stir in the flour and cook for another 10 minutes.",
    "Season with salt and pepper to taste.",
    "Serve hot over couscous or rice."
  ],
