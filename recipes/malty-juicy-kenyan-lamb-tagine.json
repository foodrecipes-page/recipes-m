      "name": "lamb shoulder",
      "amount": "1.5",
      "notes": "cut into 2-inch pieces"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1-inch piece",
      "notes": "grated"
    },
    {
      "name": "cardamom pods",
      "amount": "2",
      "notes": "crushed"
    },
    {
