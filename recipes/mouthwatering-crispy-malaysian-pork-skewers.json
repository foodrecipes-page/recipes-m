{
  "title": "Malaysian Pork Skewers",
  "description": "Buttery and crispy Malaysian pork skewers featuring cabbage and rest meat, perfect for a date night, this dish is ayurvedic tamasic friendly.",
  "cuisine": "Malaysian",
  "diet": [
    "gluten-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "pork shoulder",
      "amount": "1 pound",
      "notes": "cut into bite sized pieces"
    },
    {
      "name": "cabbage",
      "amount": "1 head",
      "notes": "shredded"
    },
    {
      "name": "butter",
      "amount": "1/4 cup",
      "notes": "melted"
    },
    {
      "name": "coconut milk",
      "amount": "1/2 cup"
    },
    {
      "name": "curry powder",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "bamboo skewers",
      "amount": "20 pieces",
      "notes": "soaked in water"
    }
  ],
  "instructions": [
    "Preheat grill to 400 degrees Fahrenheit.",
    "In a large bowl, whisk together melted butter, coconut milk, curry powder, salt, and black pepper.",
    "Add the pork pieces to the bowl and marinate for at least 30 minutes.",
    "Thread the marinated pork and shredded cabbage onto the bamboo skewers.",
    "Grill the skewers for 10-12 minutes or until the pork is cooked through.",
    "Serve hot and enjoy."
  ],
