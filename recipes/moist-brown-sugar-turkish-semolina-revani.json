  "ingredients": [
    {
      "name": "semolina",
      "amount": "1 1/2 cups",
      "notes": "fine semolina"
    },
    {
      "name": "brown sugar",
      "amount": "1 cup",
      "notes": "packed"
    },
    {
      "name": "all-purpose flour",
      "amount": "1/2 cup",
      "notes": "sifted"
    },
    {
      "name": "unsalted butter",
      "amount": "1/2 cup",
      "notes": "melted"
    },
    {
      "name": "whole milk",
      "amount": "1 cup",
      "notes": "at room temperature"
    },
    {
      "name": "rose water",
      "amount": "1 tablespoon",
      "notes": "optional"
    },
    {
      "name": "salt",
      "amount": "1/4 teaspoon",
      "notes": "to taste"
    },
    {
      "name": "namul",
      "amount": "1/4 cup",
      "notes": "blanched and seasoned"
    }
  ],
  "instructions": [
    "Preheat the oven to 350 degrees Fahrenheit.",
    "In a large mixing bowl, combine the semolina, brown sugar, and flour.",
    "Add the melted butter, milk, rose water, and salt to the bowl and mix until well combined.",
    "Stir in the blanched and seasoned namul.",
    "Pour the mixture into a lacquerware bowl and smooth the top.",
    "Bake for 35 minutes or until the edges are golden brown.",
    "Remove from the oven and let cool to room temperature.",
    "Refrigerate for at least 2 hours before slicing and serving."
  ],
