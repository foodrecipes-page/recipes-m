  "ingredients": [
    {
      "name": "boneless chicken breast",
      "amount": "1 pound",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "horseradish",
      "amount": "2 tablespoons",
      "notes": "grated"
    },
    {
      "name": "lime juice",
      "amount": "1/4 cup",
      "notes": "freshly squeezed"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "scotch bonnet peppers",
      "amount": "1",
      "notes": "seeded and chopped"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "thyme",
      "amount": "1 teaspoon",
      "notes": "dried"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the binchotan charcoal grill to medium-high heat.",
    "In a large bowl, whisk together lime juice, olive oil, horseradish, scotch bonnet peppers, garlic, thyme, salt, and black pepper.",
    "Add the chicken pieces to the bowl and toss to coat with the marinade.",
    "Thread the marinated chicken onto skewers, leaving a small space between each piece.",
    "Grill the skewers for 10-12 minutes, turning occasionally, until the chicken is cooked through.",
    "Let the skewers rest for 2 minutes before serving.",
    "Serve hot and enjoy.",
    "Garnish with fresh thyme and lime wedges, if desired."
  ],
