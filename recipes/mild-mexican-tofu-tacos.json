{
  "title": "Mild Mexican Tofu Tacos",
  "description": "A savory and comforting Mexican dish featuring tofu, sushi rice, and crispy toast. This recipe is a great option for a weeknight dinner or a casual meal with friends.",
  "cuisine": "Mexican",
  "diet": [
    "vegetarian",
    "vegan"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "Extra-firm tofu",
      "amount": "1 block (14 oz)",
      "notes": "Drained and cubed"
    },
    {
      "name": "Sushi rice",
      "amount": "1 cup",
      "notes": "Cooked according to package instructions"
    },
    {
      "name": "Lime juice",
      "amount": "2 tablespoons",
      "notes": "Freshly squeezed"
    },
    {
      "name": "Cumin",
      "amount": "1 teaspoon",
      "notes": "Ground"
    },
    {
      "name": "Chili powder",
      "amount": "1/2 teaspoon",
      "notes": "Ground"
    },
    {
      "name": "Garlic powder",
      "amount": "1/4 teaspoon",
      "notes": "Ground"
    },
    {
      "name": "Smoked paprika",
      "amount": "1/4 teaspoon",
      "notes": "Ground"
    },
    {
      "name": "Salt",
      "amount": "1/2 teaspoon",
      "notes": "Unsalted"
    },
    {
      "name": "Crispy corn tortillas",
      "amount": "4-6",
      "notes": "Torn into small pieces"
    },
    {
      "name": "Cilantro",
      "amount": "1/4 cup",
      "notes": "Chopped"
    }
  ],
  "instructions": [
    "Preheat a non-stick skillet over medium heat.",
    "Add the cumin, chili powder, garlic powder, and smoked paprika. Cook for 1 minute, stirring constantly.",
    "Add the tofu to the skillet and cook until golden brown on all sides, about 5-7 minutes.",
    "Add the lime juice to the skillet and stir to combine.",
    "Warm the tortillas by wrapping them in a damp paper towel and microwaving for 20-30 seconds.",
    "Assemble the tacos by placing a portion of the tofu mixture onto a warmed tortilla, followed by a spoonful of sushi rice and a sprinkle of cilantro.",
    "Serve immediately and enjoy!"
  ],
