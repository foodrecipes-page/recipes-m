{
  "title": "Słodka Monsoon",
  "description": "A light and refreshing Polish dish perfect for a monsoon evening. The blue color gives it a unique and whimsical touch.",
  "cuisine": "Polish",
  "diet": [
    "low-glycemic"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "oats",
      "amount": "1 cup"
    },
    {
      "name": "water",
      "amount": "2 cups"
    },
    {
      "name": "malts",
      "amount": "2 tbsp"
    },
    {
      "name": "blue food colouring",
      "amount": "5 drops"
    },
    {
      "name": "honey",
      "amount": "1 tsp"
    },
    {
      "name": "vanilla extract",
      "amount": "1 tsp"
    },
    {
      "name": "salt",
      "amount": "0.25 tsp"
    },
    {
      "name": "soda water",
      "amount": "2 cups"
    }
  ],
  "instructions": [
    "Combine oats, water, and malts in a pot. Bring mixture to a boil, then reduce heat to medium.",
    "Simmer for 10 minutes, or until oats have absorbed most of the liquid.",
    "Add blue food colouring and stir to combine.",
    "Add honey, vanilla extract, and salt. Stir until dissolved.",
    "Remove from heat and let cool.",
    "Add soda water and stir gently.",
    "Chill in the refrigerator for at least 30 minutes.",
    "Serve cold.",
    "Garnish with a sprinkle of blue food colouring, if desired."
  ],
