      "name": "tobiko",
      "amount": "1/2 cup",
      "notes": "flying fish roe"
    },
    {
      "name": "lime juice",
      "amount": "1/4 cup",
      "notes": "freshly squeezed"
    },
    {
      "name": "mirepoix",
      "amount": "1 cup",
      "notes": "onion, carrot, celery mixture"
    },
    {
      "name": "agave leaves",
      "amount": "4",
      "notes": "for serving"
    },
    {
      "name": "salt",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "coriander",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "lemon zest",
      "amount": "1 tablespoon"
    }
  ],
  "instructions": [
    "Cut the mirepoix into small pieces and saute in a pan until tender.",
    "In a large bowl, mix together the cooked mirepoix, tobiko, lime juice, salt, black pepper, and coriander.",
    "Stir well to combine and adjust the seasoning as needed.",
    "Cover the bowl with plastic wrap and refrigerate for at least 30 minutes to allow the flavors to meld.",
    "Just before serving, stir in the lemon zest.",
    "Spoon the ceviche into the agave leaves, making sure to leave a small border around the edges.",
    "Serve immediately and enjoy.",
    "Garnish with additional lime wedges and coriander if desired."
  ],
