{
  "title": "Mild German Seafood Stew",
  "description": "A resinous, snappy one-pot stew mixing frozen seafood with fermented kimchi and shojin-friendly seasonings.",
  "cuisine": "German",
  "diet": null,
  "meal": "dinner",
  "ingredients": [
    {
      "name": "frozen mixed seafood",
      "amount": "300 g",
      "notes": "shrimp, mussels, scallops"
    },
    {
      "name": "low-sodium fish stock",
      "amount": "500 ml"
    },
    {
      "name": "unsweetened coconut milk",
      "amount": "200 ml"
    },
    {
      "name": "yellow onion, diced",
      "amount": "1 medium"
    },
    {
      "name": "tomato paste",
      "amount": "1 tablespoon"
    },
    {
      "name": "fermented kimchi, chopped",
      "amount": "50 g"
    },
    {
      "name": "low-sodium soy sauce",
      "amount": "2 teaspoons"
    },
    {
      "name": "fresh basil leaves, chopped",
      "amount": "5 g"
    },
    {
      "name": "olive oil",
      "amount": "1 tablespoon"
    }
  ],
  "instructions": [
    "Heat olive oil in a large pot over medium heat until shimmering.",
    "Add diced onion and sauté until translucent, about 3 minutes.",
    "Stir in tomato paste and cook for 1 minute to release flavor.",
    "Pour in fish stock, bring to a gentle boil, then reduce heat to maintain a simmer.",
    "Add the frozen seafood and cook until they turn opaque, about 5 minutes.",
    "Stir in coconut milk, soy sauce, and chopped kimchi, then simmer gently at 90°C for 10 minutes.",
    "Remove from heat, sprinkle chopped basil, and let the stew rest for 2 minutes.",
    "Ladle into bowls and serve warm."
  ],
