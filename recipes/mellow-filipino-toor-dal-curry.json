  "instructions": [
    "Grill the onion and garlic until they are charred and softened.",
    "Grate the ginger and set it aside.",
    "Heat the olive oil in a large pot over medium heat.",
    "Add the grated ginger and cook for 1 minute.",
    "Add the curry powder and cook for 1 minute, stirring constantly.",
    "Add the toor dal and cook for 1 minute, stirring constantly.",
    "Add the grilled onion and garlic, salt, and pepper, and stir well.",
    "Pour in the coconut milk and bring the mixture to a boil.",
    "Reduce the heat to low and simmer for 20 minutes, or until the dal is tender.",
    "Stir in the chopped cilantro and serve hot."
  ],
