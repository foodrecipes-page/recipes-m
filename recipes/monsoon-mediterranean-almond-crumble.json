  "ingredients": [
    {
      "name": "2 cups almond flour"
    },
    {
      "name": "1/4 cup honey or maple syrup"
    },
    {
      "name": "1/4 cup unsalted butter, melted"
    },
    {
      "name": "3/4 cup coconut milk"
    },
    {
      "name": "1 teaspoon ground cinnamon"
    },
    {
      "name": "Pinch of salt"
    },
    {
      "name": "2 cups sliced almonds"
    },
    {
      "name": "1/2 cup pitted dates"
    }
  ],
  "instructions": [
    "Preheat oven to 350\u00b0F (175\u00b0C).",
    "In a large bowl, mix almond flour, honey or maple syrup, melted butter, coconut milk, cinnamon, and salt until well combined.",
    "Fold in sliced almonds and pitted dates.",
    "Transfer mixture onto a lined baking sheet. Bake for 20 minutes until edges are golden brown.",
    "Serve warm with a cup of coffee or tea."
