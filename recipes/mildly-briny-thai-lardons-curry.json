{
  "title": "Mildly Briny Thai Lardons Curry",
  "description": "A halal-friendly Thai curry featuring fish sauce and lardons-render, perfect for a weeknight dinner. This dish is cooked in individual mini cocottes.",
  "cuisine": "Thai",
  "diet": [
    "halal"
  ],
