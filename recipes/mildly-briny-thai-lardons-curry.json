    {
      "name": "lardons",
      "amount": "6 slices",
      "notes": "cut into small pieces"
    },
    {
      "name": "fish sauce",
      "amount": "2 tablespoons"
    },
    {
      "name": "coconut milk",
      "amount": "1 cup"
    },
    {
      "name": "Thai red curry paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "brown sugar",
      "amount": "1 teaspoon"
    },
    {
      "name": "lime juice",
      "amount": "1 tablespoon"
    },
    {
      "name": "vegetable oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "Thai basil",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat the oil in a pan over medium heat and cook the lardons until crispy.",
    "Remove the lardons from the pan and set aside.",
    "In the same pan, add the curry paste and cook for 1 minute.",
    "Add the fish sauce, coconut milk, brown sugar, and lime juice to the pan and stir to combine.",
    "Bring the mixture to a simmer and cook for 5 minutes.",
    "Stir in the cooked lardons and chopped Thai basil.",
    "Divide the curry among individual mini cocottes.",
    "Serve hot over rice or noodles."
  ],
