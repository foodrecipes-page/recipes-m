  "instructions": [
    "Preheat oven to 375°F (190°C).",
    "In a medium bowl, whisk together flour, icing sugar, and unsweetened coconut.",
    "Press mixture into the bottom of 6 ramekins.",
    "Bake for 10 minutes.",
    "In a small bowl, mix together mincemeat, coconut cream, and melted butter.",
    "Pour mincemeat mixture into the baked ramekins.",
    "In a separate bowl, whisk together egg and vanilla extract.",
    "Pour egg mixture over the mincemeat mixture in the ramekins.",
    "Sprinkle coconut flakes over the top of each ramekin.",
    "Bake for an additional 15 minutes.",
    "Dust with powdered sugar before serving."
