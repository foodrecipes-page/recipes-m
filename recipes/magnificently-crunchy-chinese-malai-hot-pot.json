      "name": "malai",
      "amount": "1 cup",
      "notes": "or substitute with coconut cream"
    },
    {
      "name": "char-grill-yang sauce",
      "amount": "1/2 cup"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 inch",
      "notes": "sliced"
    },
    {
      "name": "crunchy wonton strips",
      "amount": "1 cup"
    },
    {
      "name": "mushrooms",
      "amount": "1 cup",
      "notes": "sliced"
    },
    {
      "name": "bok choy",
      "amount": "1 cup",
      "notes": "chopped"
    },
    {
      "name": "sesame oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "soy sauce",
      "amount": "1 tablespoon"
    },
    {
      "name": "green onions",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "In a large pot, heat the sesame oil over medium heat",
    "Add the minced garlic and sliced ginger and stir-fry until fragrant",
    "Add the char-grill-yang sauce and stir-fry for 1 minute",
    "Add the malai and stir-fry until heated through",
    "Add the sliced mushrooms and chopped bok choy and stir-fry until tender",
    "Add the crunchy wonton strips and stir-fry until crispy",
    "Season with soy sauce to taste",
    "Transfer the hot pot to a serving pot and garnish with chopped green onions",
    "Serve immediately and enjoy",
    "Offer additional char-grill-yang sauce and soy sauce on the side for guests to customize"
  ],
