      "amount": "1 liter"
    },
    {
      "name": "soy sauce",
      "amount": "1 tbsp",
      "notes": "optional, for umami"
    }
  ],
  "instructions": [
    "Heat the sunflower oil in the cataplana over medium heat.",
    "Add the onion, garlic, and ginger, and sauté until fragrant.",
    "Stir in the diced tomato and cook until the tomato softens.",
    "Add the sliced steak and brown it on all sides.",
    "Pour in the beef broth, bring the mixture to a boil, then reduce heat.",
    "Add the carrot, potato, and green beans, and simmer for 10 minutes.",
    "Stir in the spinach and simmer for another 2 minutes.",
    "Season the soup with salt, pepper, and soy sauce if using.",
    "Give the soup a final stir, then serve hot straight from the cataplana."
  ],
