{
  "title": "Mindful Filipino Steak Soup",
  "description": "A dense, comforting Filipino soup with lean steak, a soffritto base, and a Buddha-friendly flavor, served in a cataplana.",
  "cuisine": "Filipino",
  "diet": null,
