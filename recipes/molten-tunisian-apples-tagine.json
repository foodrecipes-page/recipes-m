  "ingredients": [
    {
      "name": "braeburn apples",
      "amount": "4, cored and sliced"
    },
    {
      "name": "onion",
      "amount": "1, thinly sliced"
    },
    {
      "name": "garlic",
      "amount": "2 cloves, minced"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp"
    },
    {
      "name": "ground cumin",
      "amount": "1 tsp"
    },
    {
      "name": "ground coriander",
      "amount": "1 tsp"
    },
    {
      "name": "ground cinnamon",
      "amount": "1/2 tsp"
    },
    {
      "name": "honey",
      "amount": "1 tbsp"
    },
    {
      "name": "lemon juice",
      "amount": "1 tbsp"
    },
    {
      "name": "fresh cilantro",
      "amount": "2 tbsp, chopped"
    },
    {
      "name": "vegetable stock",
      "amount": "1 cup, low-sodium"
    }
  ],
  "instructions": [
    "Preheat oven to 180C.",
    "Heat olive oil in a cast-iron skillet over medium heat.",
    "Add sliced onions and cook until translucent.",
    "Stir in minced garlic and cook for 30 seconds.",
    "Add cumin, coriander and cinnamon and sauté for 1 minute.",
    "Pour in honey and lemon juice and stir to coat the onions.",
    "Add sliced apples and stir to combine.",
    "Pour in vegetable stock and bring to a gentle simmer.",
    "Transfer skillet to the preheated oven and bake for 20 minutes.",
    "Remove from oven, garnish with chopped cilantro and serve hot."
  ],
