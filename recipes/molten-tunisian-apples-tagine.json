{
  "title": "Molten Tunisian Apples Tagine",
  "description": "A sweet and savory winey tagine featuring braeburn apples, beurre monte and a fragrant blend of cumin, coriander and cinnamon, perfect for a kosher-friendly date night.",
  "cuisine": "tunisian",
  "diet": [
    "kosher"
  ],
