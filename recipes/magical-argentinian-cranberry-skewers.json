  "ingredients": [
    {
      "name": "dried cranberries",
      "amount": "1 cup",
      "notes": "unsweetened"
    },
    {
      "name": "bonito flakes",
      "amount": "1/2 cup",
      "notes": "shaved"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "garlic powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the kadhai over medium heat.",
    "Thread the dried cranberries onto skewers, leaving a small space between each cranberry.",
    "In a small bowl, mix together the bonito flakes, olive oil, lemon juice, garlic powder, salt, and black pepper.",
    "Brush the mixture onto the cranberries.",
    "Cook the skewers in the kadhai for 5 minutes, turning frequently.",
    "Garnish with chopped fresh parsley.",
    "Serve immediately.",
    "Repeat with remaining ingredients.",
    "Store leftovers in an airtight container."
  ],
