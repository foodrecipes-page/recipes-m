{
  "title": "Magical Argentinian Cranberry Skewers",
  "description": "A rich and crunchy Argentinian dish featuring dried cranberries and bonito shave, perfect for a festive snack or appetizer. This low-calorie-friendly recipe is made in a kadhai.",
  "cuisine": "Argentinian",
  "diet": [
    "low-calorie",
    "gluten-free"
  ],
