{
  "title": "Mildly Spicy Jamaican Chicken Curry",
  "description": "A flavorful and aromatic one-pot dish featuring galangal and ferment-jang, perfect for a weeknight dinner. This recipe is egg-free and friendly for various dietary needs.",
  "cuisine": "Jamaican",
  "diet": [
    "gluten-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "boneless chicken breast",
      "amount": "1 1/2 pounds",
      "notes": "cut into 1-inch pieces"
    },
    {
      "name": "galangal",
      "amount": "2 inches",
      "notes": "peeled and minced"
    },
    {
      "name": "ferment-jang",
      "amount": "2 tablespoons"
    },
    {
      "name": "curry powder",
      "amount": "2 teaspoons"
    },
    {
      "name": "coconut milk",
      "amount": "1 can"
    },
    {
      "name": "diced tomatoes",
      "amount": "1 can"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the oil in a large pot over medium heat.",
    "Add the galangal and cook until fragrant, about 1 minute.",
    "Add the chicken and cook until browned, about 5 minutes.",
    "Add the curry powder and cook for 1 minute.",
    "Stir in the ferment-jang, coconut milk, diced tomatoes, salt, and pepper.",
    "Bring the mixture to a simmer.",
    "Reduce the heat to low and cook, covered, until the chicken is cooked through, about 20 minutes.",
    "Serve hot over rice or with naan bread."
  ],
