      "amount": "12 slices",
      "notes": "thinly sliced"
    },
    {
      "name": "red onion",
      "amount": "1 large",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "red bell pepper",
      "amount": "2 large",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "zucchini",
      "amount": "2 medium",
      "notes": "cut into 1 inch slices"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "smoked paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the yakimono grill to medium high heat.",
    "In a large bowl, whisk together lemon juice, olive oil, smoked paprika, salt, and black pepper.",
    "Add the sliced Serrano ham, red onion, red bell pepper, and zucchini to the bowl and toss to coat.",
    "Thread the marinated ingredients onto skewers, leaving a small space between each piece.",
    "Grill the kebabs for 10-12 minutes, turning occasionally, until the ham is lightly charred and the vegetables are tender.",
    "Remove the kebabs from the grill and sprinkle with chopped parsley.",
    "Serve the kebabs hot, garnished with additional parsley if desired.",
    "Repeat with remaining ingredients if necessary."
  ],
