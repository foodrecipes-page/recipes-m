{
  "title": "Moist Velvety Ukrainian Bread Casserole",
  "description": "A funky and velvety Ukrainian dish featuring white bread and yuzu-cure, perfect for a crowd, this Whole30-friendly casserole is baked in a cazuela.",
  "cuisine": "Ukrainian",
  "diet": [
    "Whole30",
    "gluten-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "white bread",
      "amount": "1 loaf",
      "notes": "cut into 1 inch cubes"
    },
    {
      "name": "yuzu-cure",
      "amount": "1/4 cup"
    },
    {
      "name": "eggs",
      "amount": "6 large"
    },
    {
      "name": "coconut milk",
      "amount": "1 cup"
    },
    {
      "name": "salt",
      "amount": "1 tsp"
    },
    {
      "name": "black pepper",
      "amount": "1/2 tsp"
    },
    {
      "name": "garlic powder",
      "amount": "1/2 tsp"
    },
    {
      "name": "paprika",
      "amount": "1/4 tsp"
    }
  ],
  "instructions": [
    "Preheat the oven to 350 degrees Fahrenheit.",
    "In a large bowl, whisk together the eggs, coconut milk, salt, black pepper, garlic powder, and paprika.",
    "Add the cubed white bread to the bowl and toss until the bread is evenly coated with the egg mixture.",
    "Stir in the yuzu-cure.",
    "Pour the bread mixture into a cazuela.",
    "Bake the casserole for 35 minutes or until it is golden brown and set.",
    "Remove the casserole from the oven and let it cool for 10 minutes.",
    "Serve the casserole warm and enjoy."
  ],
