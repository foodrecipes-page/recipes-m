      "name": "Carnaroli rice",
      "amount": "1 1/2 cups",
      "notes": "preferably imported from Italy"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "celery",
      "amount": "2 stalks",
      "notes": "chopped"
    },
    {
      "name": "carrot",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "dried thyme",
      "amount": "1 teaspoon"
    },
    {
      "name": "dried parsley",
      "amount": "1 teaspoon"
    },
    {
      "name": "sea salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "white wine",
      "amount": "1 cup"
    },
    {
      "name": "vegetable broth",
      "amount": "2 cups"
    }
  ],
  "instructions": [
    "Heat the oil in a large saucepan over medium heat.",
    "Add the chopped onion, celery, and carrot, and cook until the vegetables are tender.",
    "Add the thyme, parsley, and sea salt, and cook for 1 minute.",
    "Add the Carnaroli rice and cook for 1-2 minutes, stirring constantly.",
    "Add the white wine and cook until the liquid is almost completely absorbed.",
    "Add the vegetable broth, 1/2 cup at a time, stirring constantly and allowing each portion to absorb before adding the next.",
    "Continue cooking until the rice is tender and creamy.",
    "Remove from heat and let rest for 5 minutes before serving."
  ],
