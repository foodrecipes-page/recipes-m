  "ingredients": [
    {
      "name": "boneless chicken breast",
      "amount": "1 1/2 pounds",
      "notes": "cut into 1-inch pieces"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "cumin",
      "amount": "1 teaspoon"
    },
    {
      "name": "coriander",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "amaretti cookies",
      "amount": "6 cookies",
      "notes": "crushed for garnish"
    }
  ],
  "instructions": [
    "Preheat a grill to medium-high heat",
    "In a large bowl, whisk together olive oil, lemon juice, garlic, paprika, cumin, coriander, salt, and black pepper",
    "Add the chicken to the bowl and toss to coat with the marinade",
    "Thread the marinated chicken onto bamboo skewers",
    "Place the kebabs on the grill and cook for 10-12 minutes, turning occasionally",
    "Transfer the kebabs to a bamboo steamer lined with parchment paper",
    "Cover the steamer with a papillote and steam for 5 minutes",
    "Serve the kebabs hot, garnished with crushed amaretti cookies"
  ],
