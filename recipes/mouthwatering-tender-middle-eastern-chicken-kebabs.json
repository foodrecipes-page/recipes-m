{
  "title": "Middle Eastern Chicken Kebabs",
  "description": "Tender and flavorful chicken kebabs marinated in a mix of Middle Eastern spices, perfect for a crowd-pleasing dinner",
  "cuisine": "Middle Eastern",
  "diet": [
    "gluten-free",
