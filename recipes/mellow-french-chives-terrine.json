    {
      "name": "fresh chives",
      "amount": "200 g",
      "notes": "chopped"
    },
    {
      "name": "red onion",
      "amount": "1 small",
      "notes": "finely diced"
    },
    {
      "name": "dry white wine",
      "amount": "250 ml"
    },
    {
      "name": "vegetable broth",
      "amount": "200 ml"
    },
    {
      "name": "butter",
      "amount": "50 g"
    },
    {
      "name": "goat cheese",
      "amount": "100 g",
      "notes": "crumbled"
    },
    {
      "name": "Dijon mustard",
      "amount": "2 tbsp"
    },
    {
      "name": "agar-agar powder",
      "amount": "2 tsp"
    },
    {
      "name": "white wine vinegar",
      "amount": "1 tbsp"
    },
    {
      "name": "salt",
      "amount": "1/2 tsp"
    },
    {
      "name": "black pepper",
      "amount": "1/4 tsp"
    }
  ],
  "instructions": [
    "Heat butter in a saucepan over medium heat until melted.",
    "Add diced onion and sauté until translucent.",
    "Stir in chopped chives and cook for 1 minute.",
    "Pour in dry white wine and let reduce by half, about 5 minutes.",
    "Add vegetable broth, Dijon mustard, and vinegar, stir to combine.",
    "Sprinkle agar-agar powder over the liquid and whisk until fully dissolved, then bring to a gentle boil for 2 minutes.",
    "Remove from heat and mix in crumbled goat cheese until smooth.",
    "Stir in salt and pepper, adjusting seasoning to taste.",
    "Pour the mixture into a greased 8-inch square pan and smooth the surface.",
    "Chill in the refrigerator for at least 4 hours until set and glassy."
  ],
