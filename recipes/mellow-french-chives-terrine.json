{
  "title": "Mellow French Chives Terrine",
  "description": "A silky, wine-infused chive terrine that sets into a glassy jelly, perfect for a quick luxe lunch.",
  "cuisine": "French",
  "diet": [
    "vegetarian",
    "lacto-vegetarian"
