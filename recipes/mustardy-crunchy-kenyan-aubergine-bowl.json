  "ingredients": [
    {
      "name": "aubergine",
      "amount": "2 medium",
      "notes": "any color"
    },
    {
      "name": "mustard seeds",
      "amount": "2 teaspoons",
      "notes": "black or brown"
    },
    {
      "name": "apple cider vinegar",
      "amount": "2 tablespoons",
      "notes": "or white vinegar"
    },
    {
      "name": "honey",
      "amount": "1 tablespoon"
    },
    {
      "name": "peanuts",
      "amount": "1/4 cup"
    },
    {
      "name": "coriander powder",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "cumin powder",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "black pepper",
      "amount": "to taste"
    },
    {
      "name": "candy",
      "amount": "1/4 cup (optional)",
      "notes": "for decoration"
    }
  ],
  "instructions": [
    "Preheat the oven to 200°C (400°F).",
    "Cut the aubergine into 1-inch cubes and place on a baking sheet.",
    "Roast the aubergine in the oven for 20 minutes, or until tender.",
    "In a blender or food processor, combine the mustard seeds, apple cider vinegar, honey, coriander powder, cumin powder, salt, and black pepper.",
    "Blend until smooth, adjusting the seasoning as needed.",
    "In a small pan, heat the blended sauce over medium heat until warm and fragrant.",
    "Add the peanuts to the sauce and stir to combine.",
    "To assemble the bowls, place a portion of the roasted aubergine in the bottom of each bowl.",
    "Top with the mustard sauce and peanuts, and garnish with candy if desired."
  ],
