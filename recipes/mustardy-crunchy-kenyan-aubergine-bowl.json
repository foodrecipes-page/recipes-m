{
  "title": "Mustardy Crunchy Kenyan Aubergine Bowl",
  "description": "A flavorful and crunchy Kenyan-inspired dish featuring roasted aubergine, topped with a tangy mustard sauce and crunchy peanuts.",
  "cuisine": "kenyan",
  "diet": [
    "raw-friendly",
    "gluten-free"
  ],
