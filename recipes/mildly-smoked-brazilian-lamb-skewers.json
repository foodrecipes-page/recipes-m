{
  "title": "Mildly Smoked Brazilian Lamb Skewers",
  "description": "A sweet and light solo dinner dish featuring lamb shanks with a hint of smoke, served on a wooden board, kosher friendly.",
  "cuisine": "Brazilian",
  "diet": [
    "kosher"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "lamb shanks",
      "amount": "1 pound",
      "notes": "cut into 1 inch cubes"
    },
    {
      "name": "brown sugar",
      "amount": "2 tablespoons"
    },
    {
      "name": "smoked paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "garlic powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Preheat the grill to 400 degrees Fahrenheit.",
    "In a large bowl, whisk together brown sugar, smoked paprika, garlic powder, salt, and black pepper.",
    "Add the lamb cubes to the bowl and toss to coat evenly with the spice mixture.",
    "Thread the lamb cubes onto skewers, leaving a small space between each piece.",
    "Brush the lamb skewers with olive oil and place on the grill.",
    "Close the grill lid and smoke the lamb skewers for 10 minutes.",
    "Remove the skewers from the grill and let rest for 5 minutes.",
    "Serve the lamb skewers on a wooden board, garnished with chopped parsley and a squeeze of lemon juice."
  ],
