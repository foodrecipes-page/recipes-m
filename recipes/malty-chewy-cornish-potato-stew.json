      "name": "Potatoes",
      "amount": "1 1/2 pounds",
      "notes": "Diced"
    },
    {
      "name": "Water",
      "amount": "4 cups"
    },
    {
      "name": "Guanciale",
      "amount": "6 ounces",
      "notes": "Diced"
    },
    {
      "name": "Onion",
      "amount": "1 medium",
      "notes": "Chopped"
    },
    {
      "name": "Carrots",
      "amount": "2 medium",
      "notes": "Sliced"
    },
    {
      "name": "Celery",
      "amount": "2 stalks",
      "notes": "Chopped"
    },
    {
      "name": "Malty Malt Syrup",
      "amount": "2 tablespoons"
    },
    {
      "name": "Salt",
      "amount": "1 teaspoon"
