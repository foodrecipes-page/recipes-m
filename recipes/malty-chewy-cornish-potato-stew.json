{
  "title": "Malty Chewy Cornish Potato Stew",
  "description": "A hearty, comforting Cornish stew featuring guanciale and a hint of malty sweetness. Serve with a swirl of plant-based cream.",
  "cuisine": "British",
  "diet": [
    "vegetarian",
    "vegan"
