{
  "title": "Melted Savory American Cheese Sandwich",
  "description": "A salty, cheese-pull, crowd-pleaser American dish featuring bread rolls and shio-cure, low-sodium-friendly",
  "cuisine": "American",
  "diet": [
    "low-sodium"
  ],
