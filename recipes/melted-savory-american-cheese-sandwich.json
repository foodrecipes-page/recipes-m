  "ingredients": [
    {
      "name": "Bread Rolls",
      "amount": "4",
      "notes": "Soft and lightly toasted"
    },
    {
      "name": "American Cheese",
      "amount": "8 slices",
      "notes": "Low-sodium"
    },
    {
      "name": "Shio Cure",
      "amount": "1 tsp",
      "notes": "Japanese salt cure"
    },
    {
      "name": "Unsalted Butter",
      "amount": "2 tbsp"
    },
    {
      "name": "Fresh Parsley",
      "amount": "1/4 cup",
      "notes": "Chopped"
    }
  ],
  "instructions": [
    "Preheat a non-stick skillet or griddle over medium heat",
    "Butter one side of each bread roll",
    "Place one bread roll, buttered side down, in the skillet",
    "Place two slices of American cheese on top of the bread roll",
    "Sprinkle a pinch of shio cure over the cheese",
    "Place another bread roll, buttered side up, on top of the cheese",
    "Cook for 2-3 minutes or until the bread is golden brown and the cheese is melted",
    "Flip the sandwich over and cook for an additional 2-3 minutes",
    "Repeat with remaining ingredients",
    "Serve hot and garnish with chopped fresh parsley"
  ],
