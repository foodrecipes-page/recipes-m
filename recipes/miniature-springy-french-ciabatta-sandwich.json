      "name": "canned tuna",
      "amount": "6 oz"
    },
    {
      "name": "lemon juice",
      "amount": "2 tbsp"
    },
    {
      "name": "dijon mustard",
      "amount": "1 tsp"
    },
    {
      "name": "mayonnaise",
      "amount": "1 tbsp"
    },
    {
      "name": "chopped fresh dill",
      "amount": "1 tsp"
    },
    {
      "name": "salt",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Preheat the bain-marie to 375°F (190°C).",
    "Cut the ciabatta into small squares.",
    "In a bowl, mix together the tuna, lemon juice, dijon mustard, and mayonnaise.",
    "Add the chopped dill and mix well.",
    "Place the ciabatta squares into the bain-marie and toast for 2-3 minutes.",
    "Assemble the sandwiches by placing a spoonful of the tuna salad onto a toasted ciabatta square.",
    "Serve immediately and enjoy."
