    },
    {
      "name": "black pepper",
      "amount": "1 teaspoon",
      "notes": "freshly ground"
    }
  ],
  "instructions": [
    "Combine chicken broth, fish sauce, soy sauce, and sugar in a large saucepan over medium heat. Bring to a simmer.",
    "Add the sliced ginger and cook for 2 minutes, or until fragrant.",
    "Add the clams, cover the saucepan, and cook for 3-5 minutes, or until the clams begin to open.",
    "Stir in the coconut milk and cook for an additional 2-3 minutes, or until the clams are fully opened and the broth has thickened.",
    "Season with salt and pepper to taste.",
    "Serve immediately, garnished with chopped fresh cilantro or Thai basil, if desired."
