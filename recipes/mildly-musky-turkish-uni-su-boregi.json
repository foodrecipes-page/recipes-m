  "instructions": [
    "Preheat the oven to 375°F (190°C).",
    "Steam the mushrooms and herbs until tender.",
    "In a pan, sauté the onion and garlic until softened.",
    "Add the steamed mushrooms and herbs to the pan and stir to combine.",
    "Add the uni to the pan and stir gently.",
    "Season with lemon juice and olive oil.",
    "Roll out the su-boregi pastry and cut into squares.",
    "Place a spoonful of the uni mixture onto one half of each square.",
    "Fold the pastry in half to enclose the filling.",
    "Place the su-boregi on a baking sheet and bake for 20-25 minutes.",
    "Serve warm."
  ],
