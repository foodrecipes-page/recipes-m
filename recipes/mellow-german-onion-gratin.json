{
  "title": "Mellow German Onion Gratin",
  "description": "A sweet and creamy onion gratin with a gentle German touch, ideal for a solo dinner.",
  "cuisine": "German",
  "diet": [],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "onions",
      "amount": "300g",
      "notes": "sliced thin"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp",
      "notes": "for sautéing"
    },
    {
      "name": "soy milk",
      "amount": "240ml"
    },
    {
      "name": "aquafaba",
      "amount": "1 tbsp",
      "notes": "for binding"
    },
    {
      "name": "arrowroot starch",
      "amount": "1 tbsp"
    },
    {
      "name": "smoked paprika",
      "amount": "1 tsp"
    },
    {
      "name": "sea salt",
      "amount": "1 tsp"
    },
    {
      "name": "black pepper",
      "amount": "1/2 tsp"
    },
    {
      "name": "nutritional yeast",
      "amount": "1 tbsp"
    },
    {
      "name": "vegan butter",
      "amount": "1 tbsp"
    },
    {
      "name": "apple cider vinegar",
      "amount": "1 tsp"
    }
  ],
  "instructions": [
    "Preheat oven to 180C and lightly grease a lacquerware bowl with vegan butter.",
    "Heat olive oil in a skillet over medium heat and sauté sliced onions until soft and translucent, about 10 minutes.",
    "In a small bowl, whisk soy milk, aquafaba, arrowroot starch, smoked paprika, salt, pepper, nutritional yeast, and vinegar until smooth.",
    "Pour the onion mixture into the lacquerware bowl and then pour the milk mixture over the onions, stirring gently to combine.",
    "Place the bowl in the oven and bake for 25 minutes until the top is golden and the gratin is set.",
    "Remove from oven and let rest 5 minutes before serving."
  ],
