  "ingredients": [
    {
      "name": "Chinese leaf",
      "amount": "2 bunches",
      "notes": "also known as Chinese broccoli"
    },
    {
      "name": "Olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "Onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "Garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "Ginger",
      "amount": "1 tablespoon",
      "notes": "grated"
    },
    {
      "name": "Tomato paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "Vegetable broth",
      "amount": "1 cup"
    },
    {
      "name": "Lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "Salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "Black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large skillet over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and grated ginger and cook for an additional 1 minute.",
    "Add the Chinese leaf and cook until wilted, about 3 minutes.",
    "Stir in the tomato paste and cook for 1 minute.",
    "Pour in the vegetable broth and bring the mixture to a simmer.",
    "Reduce the heat to low and let cook for 10 minutes.",
    "Stir in the lemon juice, salt, and black pepper.",
    "Serve the skillet hot, garnished with additional lemon wedges if desired."
  ],
