    {
      "name": "cod fillets",
      "amount": "1 pound",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "shrimp",
      "amount": "1/2 pound",
      "notes": "peeled and deveined"
    },
    {
      "name": "mussels",
      "amount": "1/2 pound",
      "notes": "scrubbed and debearded"
    },
    {
      "name": "brandy",
      "amount": "1/4 cup"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "tomato paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "fish stock",
      "amount": "2 cups"
    },
    {
      "name": "parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large pot over medium heat",
    "Add the chopped onion and cook until softened, about 5 minutes",
    "Add the minced garlic and cook for an additional 1 minute",
    "Add the brandy and cook until the liquid is almost completely reduced",
    "Add the tomato paste and cook for 1 minute, stirring constantly",
    "Add the fish stock and bring the mixture to a simmer",
    "Add the cod fillets, shrimp, and mussels, and poach until the seafood is cooked through",
    "Stir in the chopped parsley and season with salt and pepper to taste",
    "Serve the stew hot, garnished with additional parsley if desired"
  ],
