{
  "title": "Moist Argentinian Fish Stew",
  "description": "A hearty and flavorful Argentinian fish stew featuring brandy and a variety of seafood, perfect for a cozy dinner",
  "cuisine": "Argentinian",
  "diet": [
    "pescatarian"
  ],
