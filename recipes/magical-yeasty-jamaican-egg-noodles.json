  "ingredients": [
    {
      "name": "egg noodles",
      "amount": "8 oz",
      "notes": "preferably fresh"
    },
    {
      "name": "active dry yeast",
      "amount": "1 tsp",
      "notes": "make sure it is active"
    },
    {
      "name": "sodium alginate",
      "amount": "1 tsp"
    },
    {
      "name": "water",
      "amount": "2 cups"
    },
    {
      "name": "vegetable oil",
      "amount": "1/4 cup"
    },
    {
      "name": "soy sauce",
      "amount": "2 tbsp"
    },
    {
      "name": "scallions",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "salt",
      "amount": "1 tsp"
    }
  ],
  "instructions": [
    "Bring the water to a boil in a large pot.",
    "Add the egg noodles and cook according to the package instructions.",
    "In a small bowl, mix the yeast and sodium alginate.",
    "Add the yeast mixture to the cooked noodles and stir well.",
    "Heat the vegetable oil in a large skillet over medium heat.",
    "Add the cooked noodles to the skillet and stir fry for 2 minutes.",
    "Add the soy sauce and scallions to the skillet and stir fry for another minute.",
    "Season with salt to taste.",
    "Transfer the noodles to a ramekin and serve immediately."
  ],
