{
  "title": "Magical Yeasty Jamaican Egg Noodles",
  "description": "A crispy and romantic Jamaican dish featuring egg noodles, with a yeasty twist, served in a ramekin. This dish is perfect for a special occasion.",
  "cuisine": "Jamaican",
  "diet": [
    "vegetarian",
    "pescatarian"
  ],
