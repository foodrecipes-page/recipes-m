  "instructions": [
    "heat the binchotan charcoal in a paella pan over medium-high heat.",
    "add the olive oil and sauté the onion and garlic until softened.",
    "add the diced bell peppers and corn and cook for 2 minutes.",
    "add the diced tomatoes, black beans, cumin, and vegetable broth.",
    "add the white rice and stir to combine.",
    "reduce heat to low and simmer, covered, for 20 minutes.",
    "remove from heat and let rest for 5 minutes.",
    "fluff the rice with a fork and garnish with chopped cilantro.",
    "serve hot and enjoy!"
