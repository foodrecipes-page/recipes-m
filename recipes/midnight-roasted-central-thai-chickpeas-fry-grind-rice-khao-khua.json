{
  "title": "Midnight Roasted Central-Thai Chickpeas Fry-Grind-Rice-Khao-Khua",
  "description": "A spicy and aerated Thai dish made with chickpeas, fry-grind-rice-khao-khua, featuring a satisfying midnight craving.",
  "cuisine": "Central Thai",
  "diet": null,
