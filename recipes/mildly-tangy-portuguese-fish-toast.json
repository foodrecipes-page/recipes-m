  "ingredients": [
    {
      "name": "bread",
      "amount": "4 slices",
      "notes": "crusty bread"
    },
    {
      "name": "shio cure",
      "amount": "1/4 cup",
      "notes": "or flaky sea salt"
    },
    {
      "name": "cod fillets",
      "amount": "1 pound",
      "notes": "fresh or frozen"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit",
    "Slice the bread into 1-inch thick slices and toast until lightly browned",
    "Mix the shio cure and lemon juice in a small bowl",
    "Place the cod fillets on a baking sheet lined with parchment paper and brush with the shio cure mixture",
    "Drizzle the olive oil over the cod fillets and sprinkle with garlic and parsley",
    "Season with black pepper to taste",
    "Bake the cod fillets in the preheated oven for 12 minutes or until cooked through",
    "Assemble the toast by placing a piece of cod on each slice of toasted bread",
    "Serve immediately and enjoy"
  ],
