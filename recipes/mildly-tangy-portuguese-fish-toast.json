{
  "title": "Mildly Tangy Portuguese Fish Toast",
  "description": "A tangy and aerated Portuguese dish featuring toast, shio-cure, and dash-friendly flavors, perfect for a lazy Sunday",
  "cuisine": "Portuguese",
  "diet": [
    "pescatarian"
  ],
